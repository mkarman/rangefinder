# ─────────────────────────────────────────────────────────────────────────────
# RangeFinder — Environment Variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# Production values are injected via AWS Secrets Manager → ECS task environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local docker-compose: postgres://rangefinder:password@db:5432/rangefinder
# AWS RDS production:   postgres://user:pass@rds-endpoint.us-east-1.rds.amazonaws.com:5432/rangefinder
DATABASE_URL=postgres://rangefinder:password@db:5432/rangefinder

# ── Email Provider ────────────────────────────────────────────────────────────
# smtp  → nodemailer (use with Mailhog for local dev, or a real SMTP relay)
# ses   → AWS SES SDK v3 (production)
EMAIL_PROVIDER=smtp

# Destination address for all form submission notifications
NOTIFY_EMAIL=karman@strategicmissionelements.com

# ── SMTP Settings (EMAIL_PROVIDER=smtp) ───────────────────────────────────────
# Local Mailhog (docker-compose): host=mailhog, port=1025, no auth needed
# Real SMTP relay: fill in host/port/user/pass
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ── AWS SES Settings (EMAIL_PROVIDER=ses) ─────────────────────────────────────
# Required when deploying to AWS. The FROM address must be verified in SES.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=noreply@rangefinder.aero
